# Express HTTP port
PORT=3000

# PostgreSQL (either discrete vars or DATABASE_URL — not both unless you know what overrides)
PGHOST=your.host.or.ip
PGPORT=5432
PGUSER=postgres
PGPASSWORD=your_password
PGDATABASE=postgres

# require | disable | omit for default
PGSSLMODE=require

# DATABASE_URL=postgres://postgres:password@host:port/dbname?sslmode=require

# Resend (transactional email)
RESEND_API_TOKEN=
# Must be a verified sender in Resend (dev default: Serenidad <onboarding@resend.dev>)
RESEND_FROM_EMAIL=

# HMAC secret for OTP hashing (e.g. openssl rand -hex 32)
OTP_SECRET=

# Hetzner Object Storage (S3-compatible — optional until you upload assets)
S3_ENDPOINT=https://your-bucket.hel1.your-objectstorage.com
S3_REGION=eu-central-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Hetzner typically needs path-style URLs
S3_FORCE_PATH_STYLE=true
# Bucket name (required for profile picture uploads)
S3_BUCKET=
# Optional: full URL prefix for public objects if different from endpoint/bucket/key
# S3_PUBLIC_BASE_URL=https://your-cdn.example.com/my-bucket
